{
  "width": 500,
  "height": 376,
  "elements": [],
  "bind": [
    {
      "attr": "yAxis.data",
      "valueType": "Object",
      "defaultValue": [
        "大连",
        "北京",
        "天津",
        "青岛",
        "成都",
        "上海",
        "厦门"
      ],
      "group": "chart"
    },
    {
      "attr": "series0.data",
      "valueType": "Object",
      "defaultValue": [
        150,
        230,
        224,
        218,
        135,
        147,
        260
      ]
    },
    {
      "attr": "series1.data",
      "valueType": "Object",
      "defaultValue": [
        253,
        145,
        156,
        319,
        278,
        98,
        45
      ]
    },
    {
      "attr": "colors",
      "valueType": "Object"
    },
    {
      "attr": "chart.text",
      "valueType": "String",
      "defaultValue": "堆叠条形图",
      "name": "主标题"
    },
    {
      "attr": "chart.subtext",
      "valueType": "String",
      "defaultValue": "一个简单的堆叠条形图",
      "name": "副标题"
    },
    {
      "attr": "chart.backgroundColor",
      "valueType": "Color",
      "name": "背景色",
      "defaultValue": "#fff"
    }
  ]
}