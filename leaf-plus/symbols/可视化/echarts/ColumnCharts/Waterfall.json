{
  "width": 560,
  "height": 376,
  "elements": [],
  "bind": [
    {
      "attr": "xAxis.data",
      "valueType": "Object",
      "defaultValue": [
        "Mon",
        "Tue",
        "Wed",
        "Thu",
        "Fri",
        "Sat",
        "Sun"
      ],
      "name": "类目数据",
      "group": "chart"
    },
    {
      "attr": "series0.data",
      "valueType": "Object",
      "defaultValue": [
        20,
        20,
        20,
        20,
        20,
        20,
        20
      ],
      "name": "系列数据1"
    },
    {
      "attr": "series1.data",
      "valueType": "Object",
      "name": "系列数据2",
      "defaultValue": [
        80,
        80,
        80,
        80,
        80,
        80,
        80
      ]
    },
    {
      "attr": "chart.text",
      "valueType": "String",
      "defaultValue": "瀑布图",
      "name": "主标题"
    },
    {
      "attr": "chart.subtext",
      "valueType": "String",
      "name": "副标题",
      "defaultValue": "一个简单的瀑布图"
    },
    {
      "attr": "chart.backgroundColor",
      "valueType": "Color",
      "name": "背景色",
      "defaultValue": null
