{
  "width": 560,
  "height": 376,
  "elements": [],
  "bind": [
    {
      "attr": "xAxis.data",
      "valueType": "Object",
      "defaultValue": [
        "Mon",
        "Tue",
        "Wed",
        "Thu",
        "Fri",
        "Sat",
        "Sun"
      ],
      "name": "类目数据",
      "group": "chart"
    },
    {
      "attr": "series0.data",
      "valueType": "Object",
      "defaultValue": [
        120,
        {
          "value": 200,
          "itemStyle": {
            "color": "#ccc"
          }
        },
        150,
        80,
        70,
        110,
        130
      ],
      "name": "系列数据"
    },
    {
      "attr": "chart.text",
      "valueType": "String",
      "defaultValue": "多色柱状图",
      "name": "主标题"
    },
    {
      "attr": "chart.subtext",
      "valueType": "String",
      "defaultValue": "一个简单的多色柱状图",
      "name": "副标题"
    },
    {
      "attr": "chart.backgroundColor",
      "valueType": "Color",
      "name": "背景色",
      "defaultValue": null
    }
  ]
}