{
  "width": 560,
  "height": 376,
  "elements": [],
  "bind": [
    {
      "attr": "xAxis.data",
      "valueType": "Object",
      "group": "chart",
      "defaultValue": [
        "Mon",
        "Tue",
        "Wed",
        "Thu",
        "Fri",
        "Sat",
        "Sun"
      ]
    },
    {
      "attr": "series0.data",
      "valueType": "Object",
      "defaultValue": [
        145,
        289,
        145,
        324,
        110,
        147,
        298
      ]
    },
    {
      "attr": "series1.data",
      "valueType": "Object",
      "defaultValue": [
        78,
        98,
        78,
        347,
        95,
        78,
        189
      ]
    },
    {
      "attr": "colors",
      "valueType": "Object"
    },
    {
      "attr": "chart.text",
      "valueType": "String",
      "defaultValue": "多阶梯图",
      "name": "主标题"
    },
    {
      "attr": "chart.subtext",
      "valueType": "String",
      "defaultValue": "一个简单的多阶梯图",
      "name": "副标题"
    },
    {
      "attr": "chart.backgroundColor",
      "valueType": "Color",
      "name": "背景色",
      "defaultValue": "#fff"
    }
  ]
}