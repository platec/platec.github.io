{
  "width": 300,
  "height": 150,
  "elements": [],
  "bind": [
    {
      "attr": "div.content",
      "valueType": "Multiline",
      "defaultValue": "<h2> HT for Web</h2>\n<hr>\n<p>图扑软件 www.hightopo.com</p>",
      "name": "文本内容"
    },
    {
      "attr": "div.color",
      "valueType": "Color",
      "defaultValue": "#32D3EB",
      "name": "文本颜色"
    },
    {
      "attr": "div.background",
      "valueType": "Color",
      "defaultValue": "rgb(61,61,61)",
      "name": "背景颜色"
    },
    {
      "attr": "div.padding",
      "valueType": "Number",
      "defaultValue": 10,
      "name": "边距"
    },
    {
      "attr": "div.debug",
      "valueType": "Boolean",
      "defaultValue": false,
      "name": "调试"
    }
  ]
}