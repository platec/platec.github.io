{
  "width": 12,
  "height": 12,
  "elements": [
    {
      "type": "Polyline",
      "borderWidth": 2,
      "borderColor": "rgb(255,255,255)",
      "borderPattern": [
        2,
        1
      ],
      "borderGradientPack": {
        "func": "attr@colors"
      },
      "layoutH": "center",
      "layoutV": "top",
      "points": [
        {
          "x": 0,
          "y": 0
        },
        {
          "x": 12,
          "y": 12
        }
      ]
    },
    {
      "type": "Shape",
      "background": "rgb(255,255,255)",
      "borderColor": "#979797",
      "opacity": 0.4,
      "shape": "rect",
      "width": 8,
      "height": 8,
      "x": 6,
      "y": 6
    },
    {
      "type": "Shape",
      "background": "rgb(255,255,255)",
      "borderColor": "#979797",
      "shape": "rect",
      "width": 5,
      "height": 5,
      "x": 6,
      "y": 6
    },
    {
      "type": "Shape",
      "background": "rgb(255,255,255)",
      "borderColor": "#979797",
      "opacity": 0.6,
      "gray": true,
      "shape": "rect",
      "width": 3,
      "height": 3,
      "x": 6,
      "y": 6
    }
  ],
  "bind": [
    {
      "attr": "colors",
      "valueType": "String"
    }
  ]
}